{
  "name": "material-fidelity",
  "version": "0.1.0",
  "private": true,
  "description": "MaterialX fidelity test system for reference image generation and comparison workflows.",
  "keywords": [
    "fidelity",
    "materialx",
    "rendering",
    "testing"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "scripts": {
    "build": "tsgo -b && pnpm --filter ./third_party/three.js build && pnpm -r --if-present --filter '!./third_party/three.js' build",
    "dev": "pnpm -r --parallel --stream dev",
    "clean": "rimraf dist packages/**/dist",
    "clean:all": "pnpm clean && rimraf node_modules packages/**/node_modules",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "tsc": "tsgo -b",
    "tsgo": "tsgo -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cli": "pnpm --filter @material-fidelity/cli start",
    "viewer": "pnpm --filter @material-fidelity/viewer dev",
    "viewer:build": "pnpm --filter @material-fidelity/viewer build"
  },
  "dependencies": {
    "rimraf": "^6.1.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.35",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vitest/coverage-v8": "^4.1.5",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "pnpm@11.0.8"
}
